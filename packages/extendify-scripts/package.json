{
    "dependencies": {
        "@extendify/entrypoint": "workspace:*",
        "@extendify/scripts": "workspace:*",
        "@extendify/shared": "workspace:*"
    },
    "exports": {
        "./*": "./src/*.ts"
    },
    "name": "@extendify/scripts",
    "private": true,
    "scripts": {
        "build": "bun run src/build",
        "build-dev": "bun run src/build --dev",
        "dev": "bun run build-dev && bun run kill-proc && bun run devtools && bun run start-proc",
        "devtools": "bun run src/devtools.ts",
        "kill-proc": "bun run src/proc/kill.ts",
        "prod": "bun run build && bun run kill-proc && bun run start-proc",
        "start-proc": "bun run src/proc/start.ts",
        "update": "bun run kill-proc && bun run src/update.ts"
    }
}
